  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0412\u043E\u0437\u044C\u043C\u0438\u0442\u0435 \u0432\u0437\u0432\u0435\u0448\u0438\u0432\u0430\u0435\u043C\u043E\u0435
    \u0442\u0435\u043B\u043E \u043B\u0443\u0447\u043E\u043C \u0438 \u043F\u0435\u0440\u0435\u043D\u0435\u0441\u0438\u0442\u0435
    \u0435\u0433\u043E \u043D\u0430 \u043B\u0435\u0432\u0443\u044E \u0447\u0430\u0448\u043A\u0443.
    \u0417\u0430\u0442\u0435\u043C \u043F\u043E \u043E\u0447\u0435\u0440\u0435\u0434\u0438
    \u0437\u0430\u0445\u0432\u0430\u0442\u044B\u0432\u0430\u0439\u0442\u0435 \u0433\u0438\u0440\u0438
    (2\u202Fkg, 5\u202Fkg, 3\u202Fkg \u0438 \u0434\u0440\u0443\u0433\u0438\u0435)
    \u0438 \u043A\u043B\u0430\u0434\u0438\u0442\u0435 \u0438\u0445 \u043D\u0430 \u043F\u0440\u0430\u0432\u0443\u044E
    \u0447\u0430\u0448\u043A\u0443, \u043F\u043E\u043A\u0430 \u0432\u0435\u0441\u044B
    \u043D\u0435 \u043F\u0440\u0438\u0434\u0443\u0442 \u0432 \u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u0438\u0435.
    \u041A\u0430\u0436\u0434\u0443\u044E \u0433\u0438\u0440\u044E \u0431\u0435\u0440\u0438\u0442\u0435
    \u043E\u0442\u0434\u0435\u043B\u044C\u043D\u043E, \u043B\u0451\u0433\u043A\u0438\u043C
    \u043D\u0430\u0436\u0430\u0442\u0438\u0435\u043C \u043A\u0443\u0440\u043A\u0430.
    \u041A\u043E\u0433\u0434\u0430 \u0432\u0435\u0441\u044B \u0443\u0440\u0430\u0432\u043D\u043E\u0432\u0435\u0441\u044F\u0442\u0441\u044F,
    \u0441\u043B\u043E\u0436\u0438\u0442\u0435 \u0437\u043D\u0430\u0447\u0435\u043D\u0438\u044F
    \u0432\u0441\u0435\u0445 \u0433\u0438\u0440\u044C \u043D\u0430 \u043F\u0440\u0430\u0432\u043E\u0439
    \u0447\u0430\u0448\u043A\u0435 \u2014 \u044D\u0442\u043E \u0438 \u0435\u0441\u0442\u044C
    \u043C\u0430\u0441\u0441\u0430 \u0442\u0435\u043B\u0430. \u041D\u0435 \u043A\u043B\u0430\u0434\u0438\u0442\u0435
    \u043D\u0430 \u0432\u0435\u0441\u044B \u0431\u043E\u043B\u044C\u0448\u0435 \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0439
    \u043D\u0430\u0433\u0440\u0443\u0437\u043A\u0438, \u0443\u043A\u0430\u0437\u0430\u043D\u043D\u043E\u0439
    \u0432 \u043D\u0430\u0441\u0442\u0440\u043E\u0439\u043A\u0430\u0445. \u041F\u043E\u0441\u043B\u0435
    \u0432\u0437\u0432\u0435\u0448\u0438\u0432\u0430\u043D\u0438\u044F \u0443\u0431\u0435\u0440\u0438\u0442\u0435
    \u0432\u0441\u0435 \u0433\u0438\u0440\u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E
    ."
